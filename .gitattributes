# Auto detect text files and perform LF normalization
#	This keeps unix/windows machines from wanting to change every file
#	from the other because of the line ending (\r vs \r\n)
* text=auto

# Keep shell scripts as lf because containers will probably be running them copied in from the host, and will get confused if they're copied in with \r\n from a Windows host machine
*.sh text eol=lf
