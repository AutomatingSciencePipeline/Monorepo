# Secrets 
# You should not modify them directly inside the frontend/backend app folders, the dev-install script will replace them with the copy in the repo root

# Port configuration
FRONTEND_WEBSERVER_PORT = 3000
BACKEND_PORT = 5050
MONGODB_PORT = 27017

# If (during development) you are running outside of a docker container, change this to localhost
# so the components don't try to access a container
CONTACT_BACKEND_AT=glados-backend
CONTACT_FRONTEND_AT=glados-frontend
CONTACT_MONGODB_AT=glados-mongodb
